# Environment variables for Google Sheets integration
# Set up a webhook using Make.com, Zapier, or SheetDB
# Example for SheetDB: https://api.sheetdb.io/v1/your_spreadsheet_id
# Example for Make.com/Zapier: https://hook.make.com/your_hook_id
GOOGLE_SHEETS_WEBHOOK_URL=your_webhook_url_here

# Base URL for QR code (optional, defaults to http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
